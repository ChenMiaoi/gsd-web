{
  "name": "gsd-web",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/server/server/index.js",
  "exports": {
    ".": "./dist/server/server/index.js"
  },
  "bin": {
    "gsd-web": "./dist/server/server/index.js"
  },
  "files": [
    "dist/server/server",
    "dist/server/shared",
    "dist/web",
    "README.md"
  ],
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "clean": "node --eval \"import('node:fs/promises').then(({ rm }) => rm('dist', { recursive: true, force: true }))\"",
    "build": "npm run clean && npm run build:web && npm run build:server",
    "build:web": "vite build",
    "build:server": "tsc --project tsconfig.json",
    "prepack": "npm run build",
    "dev": "tsx src/server/index.ts",
    "cli": "npm run build && node dist/server/server/index.js",
    "start": "node dist/server/server/index.js",
    "test": "vitest run",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@fastify/static": "^8.3.0",
    "chokidar": "^4.0.3",
    "fastify": "^5.6.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^24.0.0",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^5.0.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vite": "^7.0.4",
    "vitest": "^3.2.4"
  }
}
